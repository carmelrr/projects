{
  "expo": {
    "name": "Coaching App",
    "slug": "coaching-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "coaching-app",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coaching.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.coaching.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#2563EB"
        }
      ],
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "616c7a17-6eea-4c79-8969-60793060b86b"
      }
    },
    "owner": "carmelrr"
  }
}
