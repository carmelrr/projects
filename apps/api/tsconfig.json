{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
          "module": "commonjs",
          "moduleResolution": "node",
          "outDir": "./dist",
          "rootDir": "./src",
          "declaration": false,
          "declarationMap": false,
          "emitDecoratorMetadata": true,
          "experimentalDecorators": true,
          "target": "ES2022",
          "incremental": false,
          "skipLibCheck": true,
          "strict": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "test"]
}
