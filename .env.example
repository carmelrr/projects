# Database
DATABASE_URL="postgresql://app:password@localhost:5432/coachapp?schema=public"
DIRECT_URL="postgresql://app:password@localhost:5432/coachapp?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-to-a-random-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# Firebase
FIREBASE_PROJECT_ID="my-coaching-app-xxxxx"
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# Firebase Client (for web/mobile)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="coaching-media"
R2_PUBLIC_URL=""

# Cloudflare Stream (video transcoding)
CF_STREAM_API_TOKEN=""
CF_STREAM_ACCOUNT_ID=""

# Expo Push Notifications
EXPO_ACCESS_TOKEN=""

# Email (Resend)
RESEND_API_KEY=""

# App URLs
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Misc
NODE_ENV="development"
PORT=3001
